# --- Provider mode switches: "mock" (default) needs no API keys and no
#     model downloads -- this is what backend/eval/run_eval.py and the
#     test suite (backend/tests/) run against. Switch individual pieces to
#     real providers independently: ---
DOCUTRUST_PROVIDER_MODE=mock
# ^ "mock" | "local" -- governs the embedder (backend/ingestion/embedder.py)
#   and reranker (backend/reranker/cross_encoder.py). "local" downloads
#   BAAI/bge-small-en-v1.5 + BAAI/bge-reranker-v2-m3 from HuggingFace Hub
#   on first use -- requires network access to huggingface.co.
LLM_PROVIDER=mock
# ^ "mock" | "anthropic" | "ollama" -- governs generation (backend/llm/provider.py)
WEB_SEARCH_PROVIDER=mock
# ^ "mock" | "tavily" -- governs the CRAG web fallback step (backend/graph/web_search.py)

ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
OLLAMA_MODEL=llama3.1:8b
OLLAMA_HOST=http://localhost:11434

# --- Embeddings / Reranker (local, free, no key needed) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- Vector store ---
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=docutrust_chunks

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=docutrust

# --- Web fallback search (free tier available) ---
TAVILY_API_KEY=your_tavily_key_here

# --- CRAG tuning ---
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
RELEVANCE_THRESHOLD_CORRECT=0.6
RELEVANCE_THRESHOLD_AMBIGUOUS=0.3
MAX_CORRECTION_ITERATIONS=2

# --- Server ---
APP_HOST=0.0.0.0
APP_PORT=8000
